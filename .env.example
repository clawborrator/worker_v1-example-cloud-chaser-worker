# Copy to `.env`, fill in, then `docker compose up -d`.
# Anything starting with `#` is a comment.
#
# Server identity is auto-derived from the host's kernel hostname.
# You do NOT need to edit anything per-host in this file — the same
# .env can be deployed across the entire fleet.
#
# Anthropic auth (CLAUDE_CODE_OAUTH_TOKEN) and the clawborrator
# channel token (CLAWBORRATOR_TOKEN) are NOT in this file. They live
# in ~/.clawborrator-spawn.env on the host — a shared file every
# clawborrator worker on this host reads. docker-compose.yml loads
# ~/.clawborrator-spawn.env FIRST, then this .env (this file's
# values win on conflict if you ever need to override).
#
# If ~/.clawborrator-spawn.env doesn't exist yet, create it with:
#   CLAUDE_CODE_OAUTH_TOKEN=<paste from `claude setup-token`>
#   CLAWBORRATOR_TOKEN=<paste from `npx clawborrator-cli token mint ...`>
#   CLAWBORRATOR_HUB_URL=wss://next.clawborrator.com

# Model: opus | sonnet | haiku. The cloud-chaser does measurement
# + simple judgment ("is this disk usage trending dangerous?"),
# which haiku handles fine. Bump to sonnet if you want more
# nuanced narration in the per-cycle summary the agent commits.
MODEL=haiku

# NOTE: CLAWBORRATOR_ROUTING_NAME is set automatically by
# docker-compose.yml using the host's $HOSTNAME (or
# SERVER_NAME_OVERRIDE, see bottom of file). Don't set it here.

# === REQUIRED: the agent code (the sibling repo) =================

# Where the cloud-chaser's CLAUDE.md + specialists/ live. Cloned
# into /workspace/repo on first boot; pulled on subsequent restarts.
REPO_URL=https://github.com/clawborrator/worker_v1-example-cloud-chaser-repo
REPO_REF=main
REPO_DIR_NAME=repo

# PAT for git push — the agent commits data/<server-name>/ +
# public/ every cycle. Requires `repo` scope on a GitHub PAT.
# Same PAT can be reused across all servers.
REPO_PAT=
REPO_PAT_USER=x-access-token

# Git identity for commits made by the agent.
GIT_USER_EMAIL=
GIT_USER_NAME=

# === REQUIRED: notification target ===============================

# The peer the agent calls route_to_peer against after each cycle
# to deliver a past-tense activity summary. Format is the routing
# name visible in `claw peers ls` (no `@` prefix needed). Default
# targets your own clauderemote session.
NOTIFY_PEER=clauderemote

# Only send a notification when health is amber or red. Set to 0
# to be notified every cycle (chatty). Default 1 keeps the firehose
# down on healthy servers.
NOTIFY_ON_PROBLEM_ONLY=1

# === Boot prompt =================================================
# Tell the agent that its real instructions live in the cloned repo.
CLAUDE_INITIAL_PROMPT=Read /workspace/repo/CLAUDE.md carefully — that is your playbook. Then bootstrap the cron and execute one warmup cycle.

# === Behavior knobs ==============================================

# Pass --dangerously-skip-permissions. Default "1" since this is a
# fully headless agent with no operator at the local TUI.
CLAUDE_SKIP_PERMISSIONS=1

# Skip the expect wrapper. Default 0.
DISABLE_AUTOENTER=0

# === Optional: override the auto-derived server name =============
#
# Server identity defaults to the kernel hostname (read from
# /host/etc/hostname inside the container, and from the operator's
# $HOSTNAME shell var at `docker compose up` time for the
# container_name and routing name).
#
# Set this ONLY if you want something other than the kernel hostname
# in the dashboard / commit paths / routing name — e.g. you're on
# AWS where hostnames look like "ip-10-0-1-23" and you want "prod1"
# instead. Renaming after the first cycle fragments the history.
# Lowercase + hyphens recommended.
#
# SERVER_NAME_OVERRIDE=
